# Copy this to .env and fill in your key.
# Groq API key required for live analysis.

GROQ_API_KEY=your_groq_api_key_here

# Model to use
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Max tokens for LLM response
LLM_MAX_TOKENS=4096

# One LLM call by default. Enable a single correction retry only when needed.
ALLOW_LLM_CORRECTION_RETRY=false
LLM_MAX_ATTEMPTS=1
LLM_TIMEOUT_SECONDS=60
L2_LLM_MAX_ATTEMPTS=2

# Max image file size in MB
MAX_IMAGE_SIZE_MB=10

# Output directory for reports
OUTPUT_DIR=output

# Level 3 browser scan credentials.
# Use a test account for the website you are scanning.
SCAN_USERNAME=your_scan_username
SCAN_PASSWORD=your_scan_password
BASELINE_DB_PATH=output/baselines/baselines.db
STREAMLIT_API_BASE=http://localhost:8001

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
